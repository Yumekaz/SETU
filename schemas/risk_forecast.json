{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://setu.local/schemas/risk_forecast.json",
  "title": "RiskForecast",
  "description": "7-day-ahead per-corridor risk trajectory (Phase 3 GRU forecaster output)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "forecast_id",
    "corridor",
    "origin_date",
    "horizon_days",
    "model_source",
    "training_data_through",
    "trajectory"
  ],
  "properties": {
    "forecast_id": {
      "type": "string",
      "format": "uuid"
    },
    "corridor": {
      "$ref": "corridor.json"
    },
    "origin_date": {
      "type": "string",
      "format": "date",
      "description": "Last observed score date used as forecast origin"
    },
    "horizon_days": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7
    },
    "model_source": {
      "type": "string",
      "enum": ["GRU", "TREND_FALLBACK"]
    },
    "training_data_through": {
      "type": "string",
      "format": "date",
      "description": "Latest training observation date (no look-ahead audit)"
    },
    "trajectory": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "$ref": "forecast_trajectory_step.json"
      }
    }
  }
}