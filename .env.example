# SETU Environment Configuration
# Copy to .env and fill in values as needed.

# EIA Open Data API — https://www.eia.gov/opendata/
# Required for live Brent crude / India import pulls (Phase 1+)
EIA_API_KEY=

# FRED API — https://fred.stlouisfed.org/docs/api/api_key.html
# Series DCOILBRENTEU (Brent spot) and related macro series
FRED_API_KEY=

# Backend
DATABASE_URL=sqlite:///data/setu.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Phase 1 extraction (optional — rules fallback used when unset)
SETU_LLM_MODEL_PATH=data/models/Phi-3-mini-4k-instruct-q4.gguf
SETU_EXTRACTOR_MODE=rules

# Frontend (Vite)
VITE_API_URL=http://localhost:8000